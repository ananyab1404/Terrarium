# =============================================================================
# Infinity Node — Environment Variables
# Copy to .env and fill in actual values from Terraform outputs
# =============================================================================

# AWS
AWS_REGION=us-east-1

# S3 Buckets
ARTIFACTS_BUCKET=infinity-node-artifacts-dev
LOGS_BUCKET=infinity-node-logs-dev

# SQS Queues
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/infinity-node-jobs
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/infinity-node-jobs-dlq

# DynamoDB Tables
DYNAMODB_JOBS_TABLE=infinity-node-jobs-v1
DYNAMODB_IDEMPOTENCY_TABLE=infinity-node-idempotency-v1
DYNAMODB_DEADLETTER_TABLE=infinity-node-deadletter-v1

# SNS
SNS_ALERTS_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:infinity-node-alerts

# ECS / IAM
ECS_TASK_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/infinity-node-task-role-dev
ECS_CLUSTER_NAME=infinity-node-dev

# API Configuration
API_PORT=4000
INFINITY_NODE_API_KEY=dev-api-key-change-in-production

# OpenTelemetry
OTEL_ENDPOINT=http://localhost:4318

# Worker Configuration (Person 1)
SNAPSHOT_S3_PREFIX=snapshots/default
